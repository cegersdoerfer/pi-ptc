{
  "name": "@cegersdo/pi-ptc",
  "version": "0.1.0",
  "description": "Programmatic Tool Calling (PTC) extension for pi-coding-agent - enables TypeScript code execution with async tool calls",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src/ts-runtime",
    "tools"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "pi-package",
    "pi-coding-agent",
    "pi-extension",
    "extension",
    "typescript",
    "tool-calling",
    "ptc",
    "code-execution",
    "docker"
  ],
  "pi": {
    "extensions": [
      "./dist"
    ]
  },
  "author": "Chris Egersdoerfer",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cegersdoerfer/pi-ptc.git"
  },
  "bugs": {
    "url": "https://github.com/cegersdoerfer/pi-ptc/issues"
  },
  "homepage": "https://github.com/cegersdoerfer/pi-ptc#readme",
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.32.0",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0"
  }
}
